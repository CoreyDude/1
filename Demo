namespace bibaboba
{
    internal class searchViewModel : INotifyPropertyChanged
    {
        public event PropertyChangedEventHandler? PropertyChanged;

        private void OnPropertyChanged(string propertyName)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }

        private ObservableCollection<Employee> _employee;
        readonly DataBase data = new DataBase();

        public ObservableCollection<Employee> Employee
        {
            get { return _employee; }
            set
            {
                _employee = value;
                OnPropertyChanged(nameof(Employee));
            }
        }
        private void OnUpdate()
        {
            LoadEmployee();
        }

        private void LoadEmployee()
        {
            DataBase data = new DataBase();
            DataTable dt = data.SqlSelect("select * from Employee");
            IEnumerable<Employee> employees = dt.AsEnumerable().Select(row =>
                new Employee(
                    row.Field<int>("id"),
                    row.Field<string>("FullName"),
                    row.Field<int>("Position")
                ));
            Employee = new ObservableCollection<Employee>(employees);
            data.CloseConnection();
        }

        public RelayCommand SearchCommand { get; private set; }
        public searchViewModel()
        {
            LoadEmployee();
            SearchCommand = new RelayCommand(() => Search(), () => CanSearch());
        }

        //объявляем переменную для поиска по введенному
        private string _searchText;
        public string SearchText
        {
            get { return _searchText; }
            set
            {
                if (_searchText != value)
                {
                    _searchText = value;
                    OnPropertyChanged(nameof(SearchText)); //для обновления интерфейса и привязки к ксамлу
                }
            }
        }

        //тута логка по поиску)
        private void SearchById()
        {
            string searchLol = _searchText;
            DataTable dt = data.SqlSelect($"SELECT * FROM Employee WHERE Id Like '%{searchLol}%'");
            IEnumerable<Employee> employeesCollection = dt.AsEnumerable().Select(row =>
                new Employee(
                    row.Field<int>("id"),
                    row.Field<string>("FullName"),
                    row.Field<int>("Position")
                ));
            Employee = new ObservableCollection<Employee>(employeesCollection);
            data.CloseConnection();
        }
   

        public void Search()
        {
            int idsearch;
            if (int.TryParse(SearchText, out idsearch)) //C# TryParse — это метод, который позволяет проверить допустимость строки перед попыткой преобразовать ее в определенный тип
            {
                SearchById();
            }
            else
            {
                MessageBox.Show("Неправильный формат ввода");
            }
        }

        private bool CanSearch()
        {
            return true;
        }
    }
}
