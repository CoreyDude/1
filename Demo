namespace bibaboba.Classes
{
    internal class DataBase
    {
        private static string connectionString = @"Data Source=DESKTOP-56U78RR; Initial Catalog=Globa; Integrated Security=True;";
        public SqlConnection connection = new SqlConnection(connectionString);
        public void OpenConnection()
        {
            connection.Open();
        }

        public void CloseConnection()
        {
            if (connection.State == System.Data.ConnectionState.Open)
            {
                connection.Close();
            }
        }

        // Выполнить SELECT-запрос и вернуть таблицу данных 
        public DataTable SqlSelect(string cmd)
        {
            OpenConnection();

            // Создать команду для выполнения запроса
            SqlCommand command = new SqlCommand(cmd, connection);

            // Создать адаптер данных для заполнения таблицы данных
            SqlDataAdapter adapter = new SqlDataAdapter(command);

            // Создать таблицу данных
            DataTable dt = new DataTable();

            // Заполнить таблицу данных результатами запроса
            adapter.Fill(dt);

            // Закрыть соединение с базой данных
            CloseConnection();

            // Вернуть таблицу данных
            return dt;
        }
    }
}


